{
  "name": "msnook-xyz",
  "version": "0.1.0",
  "private": true,
  "description": "workspace root — the site lives in start-app/",
  "scripts": {
    "dev": "pnpm --filter start-app dev",
    "build": "pnpm --filter start-app build",
    "start": "pnpm --filter start-app start",
    "typecheck": "pnpm --filter start-app typecheck",
    "lint": "pnpm --filter start-app lint",
    "format": "pnpm --filter start-app format && prettier --write 'supabase/**/*.sql'",
    "format:check": "pnpm --filter start-app format:check && prettier --check 'supabase/**/*.sql'",
    "migrate": "supabase db diff -f new_migration",
    "types": "supabase gen types typescript --local > start-app/src/types/supabase.ts",
    "types:production": "supabase gen types typescript --project-id hmpueymmlhhphzvebjku > start-app/src/types/supabase.ts",
    "seeds:auth": "supabase db dump --data-only --schema auth --local > ./supabase/seeds/auth.sql",
    "seeds:public": "supabase db dump --data-only --schema public --local > ./supabase/seeds/public.sql",
    "seeds:apply": "supabase db reset",
    "prepare": "husky install || true"
  },
  "devDependencies": {
    "@tanstack/intent": "^0.0.29",
    "husky": "^7.0.4",
    "oxfmt": "^0.45.0",
    "prettier": "^3.5.3",
    "prettier-plugin-sql": "^0.20.0",
    "supabase": "^2.34.3"
  },
  "packageManager": "pnpm@10.14.0"
}
